# ============================================================================
# Cursor Partnerships Hub — environment variables
# ============================================================================
#
# Copy to .env.local and fill the secrets in. NEVER commit .env.local.
# In production, configure these in Vercel project env vars (or the Cursor
# Cloud Secrets store for cloud-agent runs).

# ---- Personalized prospect demo (ChatGTM <-> Neon Postgres) -----------------

# Postgres connection string. Use a Neon project URL in production.
#   - Required by:  /api/chatgtm/prospects, /api/db/init, /api/p/[slug]/auth, /p/[slug]
#   - Format:       postgresql://USER:PASS@HOST/DB?sslmode=require
DATABASE_URL=

# Bearer token ChatGTM presents on every call into this app's API.
# Generate with: openssl rand -hex 32
CHATGTM_API_TOKEN=

# Bearer token used to bootstrap the schema (POST /api/db/init).
# Keep separate from the ChatGTM token so deploy automation has a narrower scope.
DB_INIT_TOKEN=

# 32+ byte random string used as the HMAC key for the per-slug demo unlock cookie.
# Generate with: openssl rand -hex 32
DEMO_GATE_SECRET=

# REQUIRED for the admin to work. Password for the /admin
# password gate. There is intentionally no in-code default so a forker of
# this template cannot inherit a shared password by accident. Generate
# with: openssl rand -base64 18  (or pick your own memorable phrase).
# The admin page renders a "setup required" panel until this is set.
ADMIN_PASSWORD=

# Optional separate HMAC secret for the admin session cookie. Falls
# back to DEMO_GATE_SECRET when unset, which is fine for single-
# operator deployments. Override only when explicitly rotating one
# without the other.
ADMIN_SESSION_SECRET=

# OPTIONAL. Runtime override for the canonical public origin used in
# every API-generated URL (ChatGTM `url` / `demo_url`, og:url, etc.).
# Priority order — first match wins:
#   1. PUBLIC_APP_ORIGIN (this var)
#   2. SETUP_CONFIG.canonicalOrigin (in src/lib/setup-config.ts) — used
#      in production deploys when this var is unset, so a fresh deploy
#      that forgets to set the env var still writes the right host into
#      outbound URLs (instead of falling through to the request Host
#      header, which can be a stale legacy or preview domain).
#   3. Request Host header (preview deploys + local dev only).
# Override here if you're staging or pinning the canonical at runtime.
# Format: scheme + host with no trailing slash.
PUBLIC_APP_ORIGIN=

# Pool sizing — only relevant on Vercel for tuning the Neon connection budget.
DATABASE_POOL_MAX=4

# Optional — artificial delay (ms) added to the personalized demo build so
# the "preparing your demo" UI is observable during manual testing. Set to
# 0 (or unset) in production; the real build takes ~1-3s for the logo
# prefetch alone.
PROSPECT_BUILD_DELAY_MS=0

# ---- Existing partner-demo webhooks (unchanged) -----------------------------

DATADOG_WEBHOOK_SECRET=
AWS_WEBHOOK_SECRET=
DATABRICKS_WEBHOOK_SECRET=
FIGMA_WEBHOOK_SECRET=
SENTRY_WEBHOOK_SECRET=
SNOWFLAKE_WEBHOOK_SECRET=
CURSOR_API_KEY=

# ---- Logo lookup ------------------------------------------------------------

# Optional. The logo.dev demo token works for ~99% of public domains; only
# replace with a private token if you need higher quotas.
LOGODEV_TOKEN=

# ---- Sentry -----------------------------------------------------------------

SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
