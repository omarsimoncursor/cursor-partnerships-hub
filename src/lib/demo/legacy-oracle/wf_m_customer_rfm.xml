<?xml version="1.0" encoding="UTF-8"?>
<!-- ================================================================= -->
<!-- Informatica PowerCenter mapping export.                           -->
<!-- Repository: ACME_PC_REPO · Folder: ACME_DW_MARKETING              -->
<!-- Last modified: 2021-08-14 · alex.chen@acme.example                -->
<!-- LEGACY: Target translation — Delta Live Tables (dlt.table) + DLT  -->
<!--         pipeline in Python. Source Qualifier → Spark read_stream, -->
<!--         Expression → column derivations, Aggregator → groupBy +   -->
<!--         agg, Target → @dlt.table with Unity Catalog identifiers.  -->
<!-- ================================================================= -->
<POWERMART CREATION_DATE="08/14/2021 10:23:17" REPOSITORY_VERSION="10.2">
  <REPOSITORY NAME="ACME_PC_REPO" VERSION="10.2" CODEPAGE="UTF-8" DATABASETYPE="Oracle">
    <FOLDER NAME="ACME_DW_MARKETING" GROUP="" OWNER="alex.chen" SHARED="NOTSHARED">

      <SOURCE NAME="ACME_DW.CUSTOMERS" DBDTYPE="Oracle" OWNERNAME="ACME_DW" DATABASETYPE="Oracle">
        <SOURCEFIELD NAME="CUSTOMER_ID"  DATATYPE="number(p,s)" PRECISION="18" SCALE="0" FIELDNUMBER="1" NULLABLE="NOTNULL" KEYTYPE="PRIMARY KEY"/>
        <SOURCEFIELD NAME="STATUS_CD"    DATATYPE="char"        PRECISION="1"  SCALE="0" FIELDNUMBER="2" NULLABLE="NULL"/>
        <SOURCEFIELD NAME="TIER_CODE"    DATATYPE="varchar2"    PRECISION="16" SCALE="0" FIELDNUMBER="3" NULLABLE="NULL"/>
      </SOURCE>

      <SOURCE NAME="ACME_DW.ORDERS" DBDTYPE="Oracle" OWNERNAME="ACME_DW" DATABASETYPE="Oracle">
        <SOURCEFIELD NAME="ORDER_ID"     DATATYPE="number(p,s)" PRECISION="18" SCALE="0" FIELDNUMBER="1" NULLABLE="NOTNULL" KEYTYPE="PRIMARY KEY"/>
        <SOURCEFIELD NAME="CUSTOMER_ID"  DATATYPE="number(p,s)" PRECISION="18" SCALE="0" FIELDNUMBER="2" NULLABLE="NOTNULL"/>
        <SOURCEFIELD NAME="ORDER_DT"     DATATYPE="date"                                     FIELDNUMBER="3" NULLABLE="NOTNULL"/>
        <SOURCEFIELD NAME="GROSS_AMOUNT" DATATYPE="number(p,s)" PRECISION="18" SCALE="2" FIELDNUMBER="4" NULLABLE="NULL"/>
      </SOURCE>

      <TARGET NAME="ACME_DW.MART_CUSTOMER_RFM" DATABASETYPE="Oracle">
        <TARGETFIELD NAME="CUSTOMER_ID"  DATATYPE="number(p,s)" PRECISION="18" FIELDNUMBER="1" KEYTYPE="PRIMARY KEY"/>
        <TARGETFIELD NAME="RUN_YM"       DATATYPE="char"        PRECISION="6"  FIELDNUMBER="2" KEYTYPE="PRIMARY KEY"/>
        <TARGETFIELD NAME="RECENCY_DAYS" DATATYPE="number(p,s)" PRECISION="6"  FIELDNUMBER="3"/>
        <TARGETFIELD NAME="ORDER_COUNT"  DATATYPE="number(p,s)" PRECISION="8"  FIELDNUMBER="4"/>
        <TARGETFIELD NAME="GROSS_SALES"  DATATYPE="number(p,s)" PRECISION="18" SCALE="2" FIELDNUMBER="5"/>
        <TARGETFIELD NAME="R_SCORE"      DATATYPE="number(p,s)" PRECISION="1"  FIELDNUMBER="6"/>
        <TARGETFIELD NAME="F_SCORE"      DATATYPE="number(p,s)" PRECISION="1"  FIELDNUMBER="7"/>
        <TARGETFIELD NAME="M_SCORE"      DATATYPE="number(p,s)" PRECISION="1"  FIELDNUMBER="8"/>
        <TARGETFIELD NAME="RFM_CELL"     DATATYPE="char"        PRECISION="3"  FIELDNUMBER="9"/>
        <TARGETFIELD NAME="SEGMENT_NAME" DATATYPE="varchar2"    PRECISION="32" FIELDNUMBER="10"/>
      </TARGET>

      <MAPPING NAME="m_customer_rfm" ISVALID="YES" DESCRIPTION="RFM segmentation refresh (weekly)">

        <TRANSFORMATION NAME="SQ_CUSTOMERS_ORDERS" TYPE="Source Qualifier">
          <TRANSFORMFIELD NAME="CUSTOMER_ID"   PORTTYPE="OUTPUT" DATATYPE="number(p,s)"/>
          <TRANSFORMFIELD NAME="STATUS_CD"     PORTTYPE="OUTPUT" DATATYPE="char"/>
          <TRANSFORMFIELD NAME="LAST_ORDER_DT" PORTTYPE="OUTPUT" DATATYPE="date"/>
          <TRANSFORMFIELD NAME="ORDER_COUNT"   PORTTYPE="OUTPUT" DATATYPE="number(p,s)"/>
          <TRANSFORMFIELD NAME="GROSS_SALES"   PORTTYPE="OUTPUT" DATATYPE="number(p,s)"/>
          <TABLEATTRIBUTE NAME="Sql Query" VALUE="
            SELECT c.customer_id,
                   c.status_cd,
                   NVL(MAX(o.order_dt), DATE '1900-01-01') AS last_order_dt,
                   COUNT(o.order_id)                       AS order_count,
                   NVL(SUM(o.gross_amount), 0)             AS gross_sales
              FROM acme_dw.customers c
              LEFT JOIN acme_dw.orders o
                ON o.customer_id = c.customer_id
               AND o.order_dt   >= ADD_MONTHS(SYSDATE, -24)
             WHERE c.status_cd IN ('A','H')
             GROUP BY c.customer_id, c.status_cd
          "/>
          <TABLEATTRIBUTE NAME="User Defined Join" VALUE=""/>
          <TABLEATTRIBUTE NAME="Source Filter"     VALUE=""/>
          <TABLEATTRIBUTE NAME="Number Of Sorted Ports" VALUE="1"/>
        </TRANSFORMATION>

        <TRANSFORMATION NAME="EXP_DERIVE_RECENCY" TYPE="Expression" DESCRIPTION="Derive recency and run_ym">
          <TRANSFORMFIELD NAME="CUSTOMER_ID"    PORTTYPE="INPUT/OUTPUT"/>
          <TRANSFORMFIELD NAME="LAST_ORDER_DT"  PORTTYPE="INPUT/OUTPUT"/>
          <TRANSFORMFIELD NAME="ORDER_COUNT"    PORTTYPE="INPUT/OUTPUT"/>
          <TRANSFORMFIELD NAME="GROSS_SALES"    PORTTYPE="INPUT/OUTPUT"/>
          <TRANSFORMFIELD NAME="RUN_YM"         PORTTYPE="OUTPUT"
                          EXPRESSION="TO_CHAR(SYSDATE,'YYYYMM')"/>
          <TRANSFORMFIELD NAME="RECENCY_DAYS"   PORTTYPE="OUTPUT"
                          EXPRESSION="GREATEST(TRUNC(SYSDATE) - LAST_ORDER_DT, 0)"/>
        </TRANSFORMATION>

        <TRANSFORMATION NAME="AGG_QUINTILE_SCORES" TYPE="Aggregator" DESCRIPTION="NTILE(5) scores">
          <TRANSFORMFIELD NAME="CUSTOMER_ID"  PORTTYPE="INPUT/OUTPUT"/>
          <TRANSFORMFIELD NAME="RUN_YM"       PORTTYPE="INPUT/OUTPUT"/>
          <TRANSFORMFIELD NAME="R_SCORE"      PORTTYPE="OUTPUT"
                          EXPRESSION="NTILE(5) OVER (ORDER BY RECENCY_DAYS ASC)"/>
          <TRANSFORMFIELD NAME="F_SCORE"      PORTTYPE="OUTPUT"
                          EXPRESSION="NTILE(5) OVER (ORDER BY ORDER_COUNT DESC)"/>
          <TRANSFORMFIELD NAME="M_SCORE"      PORTTYPE="OUTPUT"
                          EXPRESSION="NTILE(5) OVER (ORDER BY GROSS_SALES DESC)"/>
          <TRANSFORMFIELD NAME="RFM_CELL"     PORTTYPE="OUTPUT"
                          EXPRESSION="TO_CHAR(NVL(R_SCORE,0)) || TO_CHAR(NVL(F_SCORE,0)) || TO_CHAR(NVL(M_SCORE,0))"/>
          <TABLEATTRIBUTE NAME="Group By Ports" VALUE="CUSTOMER_ID,RUN_YM"/>
        </TRANSFORMATION>

        <TRANSFORMATION NAME="EXP_SEGMENT_NAME" TYPE="Expression" DESCRIPTION="DECODE RFM cell → segment">
          <TRANSFORMFIELD NAME="RFM_CELL"     PORTTYPE="INPUT/OUTPUT"/>
          <TRANSFORMFIELD NAME="SEGMENT_NAME" PORTTYPE="OUTPUT"
                          EXPRESSION="DECODE(RFM_CELL,'555','Champion','554','Champion','544','Loyal','455','Loyal','344','Promising','255','At Risk','155','Hibernating','111','Lost','Other')"/>
        </TRANSFORMATION>

        <CONNECTOR FROMFIELD="CUSTOMER_ID"  FROMINSTANCE="SQ_CUSTOMERS_ORDERS" TOFIELD="CUSTOMER_ID"  TOINSTANCE="EXP_DERIVE_RECENCY"/>
        <CONNECTOR FROMFIELD="LAST_ORDER_DT" FROMINSTANCE="SQ_CUSTOMERS_ORDERS" TOFIELD="LAST_ORDER_DT" TOINSTANCE="EXP_DERIVE_RECENCY"/>
        <CONNECTOR FROMFIELD="RUN_YM"        FROMINSTANCE="EXP_DERIVE_RECENCY"  TOFIELD="RUN_YM"        TOINSTANCE="AGG_QUINTILE_SCORES"/>
        <CONNECTOR FROMFIELD="RECENCY_DAYS"  FROMINSTANCE="EXP_DERIVE_RECENCY"  TOFIELD="RECENCY_DAYS"  TOINSTANCE="AGG_QUINTILE_SCORES"/>
        <CONNECTOR FROMFIELD="ORDER_COUNT"   FROMINSTANCE="EXP_DERIVE_RECENCY"  TOFIELD="ORDER_COUNT"   TOINSTANCE="AGG_QUINTILE_SCORES"/>
        <CONNECTOR FROMFIELD="GROSS_SALES"   FROMINSTANCE="EXP_DERIVE_RECENCY"  TOFIELD="GROSS_SALES"   TOINSTANCE="AGG_QUINTILE_SCORES"/>
        <CONNECTOR FROMFIELD="RFM_CELL"      FROMINSTANCE="AGG_QUINTILE_SCORES" TOFIELD="RFM_CELL"      TOINSTANCE="EXP_SEGMENT_NAME"/>
        <CONNECTOR FROMFIELD="CUSTOMER_ID"   FROMINSTANCE="AGG_QUINTILE_SCORES" TOFIELD="CUSTOMER_ID"   TOINSTANCE="ACME_DW.MART_CUSTOMER_RFM"/>
        <CONNECTOR FROMFIELD="RUN_YM"        FROMINSTANCE="AGG_QUINTILE_SCORES" TOFIELD="RUN_YM"        TOINSTANCE="ACME_DW.MART_CUSTOMER_RFM"/>
        <CONNECTOR FROMFIELD="SEGMENT_NAME"  FROMINSTANCE="EXP_SEGMENT_NAME"    TOFIELD="SEGMENT_NAME"  TOINSTANCE="ACME_DW.MART_CUSTOMER_RFM"/>
      </MAPPING>

      <WORKFLOW NAME="wf_m_customer_rfm" DESCRIPTION="Weekly RFM refresh" SCHEDULERNAME="wk_monday_03_15_pst">
        <SESSION NAME="s_m_customer_rfm" MAPPINGNAME="m_customer_rfm" REUSABLE="NO">
          <SESSIONEXTENSION TYPE="Reader">
            <CONNECTIONREFERENCE NAME="ACME_DW_ORACLE_READ" CONNECTIONTYPE="Relational"/>
          </SESSIONEXTENSION>
          <SESSIONEXTENSION TYPE="Writer">
            <CONNECTIONREFERENCE NAME="ACME_DW_ORACLE_WRITE" CONNECTIONTYPE="Relational"/>
          </SESSIONEXTENSION>
          <CONFIGREFERENCE REFOBJECTNAME="default_session_config"/>
        </SESSION>
      </WORKFLOW>

    </FOLDER>
  </REPOSITORY>
</POWERMART>
